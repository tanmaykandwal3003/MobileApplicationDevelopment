<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_surface"
    android:orientation="vertical"
    android:padding="20dp"
    tools:context=".MainActivity">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8dp"
        android:text="@string/home_title"
        android:textColor="@color/text_primary"
        android:textSize="30sp"
        android:textStyle="bold" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="32dp"
        android:text="@string/home_subtitle"
        android:textColor="@color/text_secondary"
        android:textSize="15sp" />

    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp"
        app:cardBackgroundColor="@color/card_surface"
        app:cardCornerRadius="16dp"
        app:cardElevation="0dp"
        app:strokeColor="#E3E8F1"
        app:strokeWidth="1dp">

        <Button
            android:id="@+id/buttonTakePhoto"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:backgroundTint="@color/brand_primary"
            android:text="@string/take_photo"
            android:textAllCaps="false"
            android:textColor="@color/white"
            android:textSize="17sp" />
    </com.google.android.material.card.MaterialCardView>

    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardBackgroundColor="@color/card_surface"
        app:cardCornerRadius="16dp"
        app:cardElevation="0dp"
        app:strokeColor="#E3E8F1"
        app:strokeWidth="1dp">

        <Button
            android:id="@+id/buttonOpenFolder"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:backgroundTint="@color/brand_primary_dark"
            android:text="@string/open_folder"
            android:textAllCaps="false"
            android:textColor="@color/white"
            android:textSize="17sp" />
    </com.google.android.material.card.MaterialCardView>

</LinearLayout>