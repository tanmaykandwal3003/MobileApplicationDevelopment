<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0F0B1E"
    android:orientation="vertical"
    android:paddingStart="14dp"
    android:paddingTop="12dp"
    android:paddingEnd="14dp"
    android:paddingBottom="10dp"
    tools:context=".MainActivity">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="10dp"
        android:text="@string/home_title"
        android:textColor="#DDD7FF"
        android:textSize="40sp"
        android:textStyle="bold" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp"
        android:orientation="horizontal">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/buttonTakePhoto"
            style="@style/Widget.Material3.Button"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_weight="1"
            android:backgroundTint="#C6B5FF"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:text="@string/take_photo"
            android:textAllCaps="false"
            android:textColor="#2D2548"
            android:textSize="14sp"
            app:cornerRadius="16dp" />

        <Space
            android:layout_width="14dp"
            android:layout_height="1dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/buttonOpenFolder"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_weight="1"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:text="@string/choose_folder"
            android:textAllCaps="false"
            android:textColor="#C6B5FF"
            android:textSize="14sp"
            app:cornerRadius="16dp"
            app:strokeColor="#31284D"
            app:strokeWidth="1dp" />
    </LinearLayout>

    <TextView
        android:id="@+id/textSelectedFolder"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8dp"
        android:text="@string/no_images_to_display"
        android:textAlignment="center"
        android:textColor="#756E8F"
        android:textSize="12sp"
        android:visibility="gone" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerHomeImages"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:paddingStart="2dp"
        android:paddingEnd="2dp"
        android:paddingBottom="10dp"
        tools:listitem="@layout/item_image_grid" />

    <TextView
        android:id="@+id/textHomeEmpty"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingBottom="10dp"
        android:text="@string/no_images_to_display"
        android:textAlignment="center"
        android:textColor="#756E8F"
        android:textSize="14sp" />

</LinearLayout>